PORT=3000
NODE_ENV=development

# Must be the same secret used by all downstream services
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Downstream service URLs (internal network)
LOCATION_SERVICE_URL=http://localhost:3001
MESSAGE_SERVICE_URL=http://localhost:3002

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=3000
RATE_LIMIT_HEALTH_WINDOW_MS=60000
RATE_LIMIT_HEALTH_MAX=60
